# =====================================================================
# AI Meeting Intelligence Platform — Environment Configuration
# ---------------------------------------------------------------------
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# NEVER commit `.env` to version control (it is in .gitignore).
# In production, inject these via your orchestrator's secret manager
# (AWS Secrets Manager, Kubernetes Secrets, etc.), not a file.
# =====================================================================

# ---------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------
# ENVIRONMENT: development | staging | production
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
# LOG_FORMAT: console (human-readable, dev) | json (machine-readable, prod)
LOG_FORMAT=console
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Public URL the BROWSER uses to reach the backend API. Baked into the
# frontend at build time. In production set this to your real API URL,
# e.g. https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# ---------------------------------------------------------------------
# Security (used by the auth module)
# Generate a strong key:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# ---------------------------------------------------------------------
SECRET_KEY=dev-only-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
# Brute-force protection on auth endpoints (disable only for load tests)
RATE_LIMIT_ENABLED=true
# Base URL used in password-reset links sent to users
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------------
# PostgreSQL
# NOTE: inside Docker Compose, POSTGRES_HOST is overridden to `postgres`
# ---------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=meeting_user
POSTGRES_PASSWORD=dev_password_change_me
POSTGRES_DB=meeting_platform

# ---------------------------------------------------------------------
# Redis (broker + cache). Inside Compose, REDIS_HOST becomes `redis`.
# ---------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------------------------------------------------------------------
# Object Storage (MinIO locally, AWS S3 in production — same API)
# Inside Compose, S3_ENDPOINT_URL becomes http://minio:9000
# ---------------------------------------------------------------------
STORAGE_PROVIDER=s3
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_dev_password
S3_BUCKET=meeting-files
S3_REGION=us-east-1

# ---------------------------------------------------------------------
# ChromaDB (vector store). Inside Compose, CHROMA_HOST becomes `chromadb`.
# ---------------------------------------------------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ---------------------------------------------------------------------
# AI Providers
# ---------------------------------------------------------------------
# LLM_PROVIDER: openai (default) | ollama (added later via provider pattern)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# TRANSCRIPTION_PROVIDER: local (faster-whisper, free) | openai (Whisper API)
TRANSCRIPTION_PROVIDER=local
# WHISPER_MODEL_SIZE: tiny | base | small | medium (bigger = slower + better)
WHISPER_MODEL_SIZE=base
# WHISPER_DEVICE: cpu (default) | cuda (for GPU hosts)
WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE: int8 (default/CPU optimized) | float16 (GPU optimized) | int8_float16
WHISPER_COMPUTE_TYPE=int8

# HuggingFace token for Pyannote speaker diarization.
# Leave EMPTY to gracefully skip diarization (transcript still works).
HF_TOKEN=
# DIARIZATION_PROVIDER: auto (pyannote if HF_TOKEN set, else skip) | stub | disabled
DIARIZATION_PROVIDER=auto

# Embeddings model (Sentence Transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
